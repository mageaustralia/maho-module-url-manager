{
    "name": "mageaustralia/maho-module-url-manager",
    "description": "URL redirect manager + 404 logging + email reports for Maho",
    "type": "maho-module",
    "license": "OSL-3.0",
    "homepage": "https://github.com/mageaustralia/maho-module-url-manager",
    "authors": [
        {
            "name": "Mage Australia",
            "email": "dev@mageaustralia.com.au",
            "homepage": "https://mageaustralia.com.au"
        }
    ],
    "require": {
        "php": ">=8.3",
        "mahocommerce/maho": "^26.5"
    },
    "autoload": {
        "psr-0": {
            "MageAustralia_UrlManager_": "app/code/local/"
        }
    },
    "extra": {
        "map": [
            ["app/code/local/MageAustralia/UrlManager", "app/code/local/MageAustralia/UrlManager"],
            ["app/design/adminhtml/default/default/layout/mageaustralia/urlmanager.xml", "app/design/adminhtml/default/default/layout/mageaustralia/urlmanager.xml"],
            ["app/design/frontend/base/default/layout/mageaustralia/urlmanager.xml", "app/design/frontend/base/default/layout/mageaustralia/urlmanager.xml"],
            ["app/design/frontend/base/default/template/mageaustralia/urlmanager", "app/design/frontend/base/default/template/mageaustralia/urlmanager"],
            ["app/design/frontend/base/default/template/email/mageaustralia_urlmanager", "app/design/frontend/base/default/template/email/mageaustralia_urlmanager"],
            ["app/etc/modules/MageAustralia_UrlManager.xml", "app/etc/modules/MageAustralia_UrlManager.xml"],
            ["app/locale/en_US/template/email/mageaustralia_urlmanager", "app/locale/en_US/template/email/mageaustralia_urlmanager"]
        ]
    }
}
